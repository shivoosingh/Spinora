NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth providers — configure in Supabase Dashboard:
# 1. Authentication → Providers → Phone (enable + add Twilio/MessageBird for SMS)
# 2. Authentication → Providers → Google (OAuth client ID + secret)
# 3. Authentication → URL Configuration → add redirect: http://localhost:3000/auth/callback

# Social media links (footer)
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/yourusername
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/yourpage
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/1234567890
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourusername
